@model IEnumerable<Mediacrit_Review.Models.Review>

@{
    ViewData[index: "Title"] = "Listado de reseñas";
}

<div>
    <div class="d-flex justify-content-between align-items-center my-4">
        <h2>LISTADO DE RESEÑAS</h2>
        <a asp-action="Create" class="btn btn-success">Nueva Reseña</a>
    </div>

    <div>
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Usuario</th>
                    <th>Media</th>
                    <th>Rating</th>
                    <th>Commentario</th>
                    <th>Fecha de creacion</th>
                    <th class ="text-center">Acciones</th>
                </tr>
                <thead>
                    <tbody>
                        @foreach (var Rewiew in Model)
                        {
                            <tr>
                                <td>@Rewiew.User?.Username</td>
                                <td>@Rewiew.Media?.Title</td>
                                <td>@Rewiew.Rating</td>
                                <td>@Rewiew.Comment</td>
                                <td>@Rewiew.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>
                                    <a asp-action="Edit" asp-route-id="@Rewiew.Id">Editar</a>
                                    <form asp-action="Delete" asp-route-id="@Rewiew.Id" method="post" onsubmit="return confirm('¿Estás seguro de que deseas eliminar esta reseña?');">
                                        <button type="submit">Eliminar</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>