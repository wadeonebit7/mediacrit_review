@model Mediacrit_Review.Models.Review

@{
    ViewData["Title"] = "CREAR RESEÑA";
}

<h2>Crear Nueva Reseña</h2>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>



            <div class="form-group mb-3">
                <label asp-for="UserId" class="control-label">ID de Usuario</label>
                <input asp-for="UserId" class="form-control" type="number" />
                <span asp-validation-for="UserId" class="text-danger"></span>
            </div>



            <div class="form-group mb-3">
                <label asp-for="MediaId" class="control-label">ID de Contenido/Media</label>
                <input asp-for="MediaId" class="form-control" type="number" />
                <span asp-validation-for="MediaId" class="text-danger"></span>
            </div>



            <div class="form-group mb-3">
                <label asp-for="Rating" class="control-label">Calificación (1 al 5)</label>
                <input asp-for="Rating" class="form-control" type="number" min="1" max="5" />
                <span asp-validation-for="Rating" class="text-danger"></span>
            </div>



            <div class="form-group mb-3">
                <label asp-for="Comment" class="control-label">Comentario (Opcional)</label>
                <textarea asp-for="Comment" class="form-control" rows="4" maxlength="1000"></textarea>
                <span asp-validation-for="Comment" class="text-danger"></span>
            </div>



            <div class="form-group form-check mb-4">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="IsRecommended" /> ¿Recomiendas este contenido?
                </label>
                <span asp-validation-for="IsRecommended" class="text-danger"></span>
            </div>



            <div class="form-group">
                <button type="submit" class="btn btn-primary">Guardar Reseña</button>
                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}