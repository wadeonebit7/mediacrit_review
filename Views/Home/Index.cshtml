@model IEnumerable<Mediacrit_Review.Models.Review>

@{
    ViewData["Title"] = "MediaCritIQ - Home";
}

<div class="text-center my-4">
    <h1 class="display-4">MediaCritIQ 🎬📚</h1>
    <p class="lead">Enterprise Media Review Dashboard</p>

    @if (ViewBag.CanConnect != null && ViewBag.CanConnect == true)
    {
        <div class="alert alert-success d-inline-block" role="alert">
            <i class="bi bi-check-circle-fill"></i> MySQL Connection established successfully!
        </div>
    }
    else
    {
        <div class="alert alert-danger d-inline-block" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i> Connection Error: Please verify appsettings.json.
        </div>
    }
</div>

<div class="container mt-5">
    <h2 class="mb-4">Latest Community Reviews</h2>

    <div class="row">
        @foreach (var review in Model)
        {
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card h-100 shadow-sm">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <span class="badge bg-primary">@review.Media?.Type</span>
                        <small class="text-muted">By: @review.User?.Username</small>
                    </div>
                    <div class="card-body">
                        <h5 class="card-title">@review.Media?.Title</h5>
                        <h6 class="card-subtitle mb-2 text-muted">@review.Media?.Creator (@review.Media?.ReleaseYear)</h6>

                        <p class="card-text mt-3">"@review.Comment"</p>

                        <div class="mt-3">
                            <strong>Rating:</strong>
                            <span class="text-warning">
                                @string.Concat(Enumerable.Repeat("★", review.Rating))
                                @string.Concat(Enumerable.Repeat("☆", 5 - review.Rating))
                            </span>
                        </div>
                    </div>
                    <div class="card-footer bg-transparent border-top-0 mb-2">
                        @if (review.IsRecommended)
                        {
                            <span class="text-success"><i class="bi bi-hand-thumbs-up-fill"></i> Recommended</span>
                        }
                        else
                        {
                            <span class="text-danger"><i class="bi bi-hand-thumbs-down-fill"></i> Not Recommended</span>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>