@model Mediacrit_Review.Models.Media

@{
    ViewData[index: "Title"] = "Crear nuevo contenido";
}


<h2>Crear nuevo contenido</h2>

<form asp-action="Create">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="form-group mp-3">
        <label asp-for="Title" class="control-label fw-bold"></label>
        <input asp-for="Title" placeholder="Nombre del contenido" class="form-control" />
        <span asp-validation-for="Title" class="text-danger"></span>
    </div>

    <div class="form-group mp-3">
        <label asp-for="Type" class="control-label fw-bold"></label>
        <input asp-for="Type" placeholder="Tipo de contenido" class="form-control" />
        <span asp-validation-for="Type" class="text-danger"></span>
    </div>

    <div class="form-group mp-3">
        <label asp-for="Creator" class="control-label fw-bold"></label>
        <input asp-for="Creator" placeholder="Creador del contenido" class="form-control" />
        <span asp-validation-for="Creator" class="text-danger"></span>
    </div>

    <div class="form-group mp-3">
        <label asp-for="ReleaseYear" class="control-label fw-bold"></label>
        <input asp-for="ReleaseYear" placeholder="Año de lanzamiento" class="form-control" />
        <span asp-validation-for="ReleaseYear" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Crear Contenido</button>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}